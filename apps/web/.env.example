# Web app — public env vars only. Copy to .env.local and fill in.
# The Worker holds every secret; nothing here is sensitive.

# Cloudflare Worker public origin (iframe src + /api/stumble target)
NEXT_PUBLIC_WORKER_URL=https://p.geostumble.xyz

# Jazz Cloud sync server (browser peer)
NEXT_PUBLIC_JAZZ_PEER=wss://cloud.jazz.tools/sync

# RoomRegistry CoValue id — emitted by the Jazz seed script.
# See Implementation/Jazz/v1-proposal.md §7 step 7.
NEXT_PUBLIC_JAZZ_REGISTRY_ID=

# Mux environment key for the <MuxPlayer> component
NEXT_PUBLIC_MUX_ENV_KEY=
